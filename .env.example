# LLM провайдер: ollama | openrouter
LLM_PROVIDER=ollama

# --- Ollama (локально) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=huihui_ai/qwen2.5-abliterate:32b-instruct

# --- OpenRouter (опционально, если переключишься на облако) ---
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=mistralai/mistral-nemo

# где хранятся карточки персонажей
CHARACTERS_DIR=data/characters

# --- Память (backend, см. rag.py / summarize.py) ---
# Эмбеддинг-модель для RAG-памяти (ollama pull nomic-embed-text). RAG_ENABLED=0 — выкл.
RAG_EMBED_MODEL=nomic-embed-text
# Модель для rolling-summary («story so far»). Лёгкая быстрая модель, чтобы не
# занимать большую чат-модель на пересказ. Пусто = использовать OLLAMA_MODEL.
# SUMMARY_ENABLED=0 — выкл.
SUMMARY_MODEL=llama3.1:8b
